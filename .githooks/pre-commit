#!/usr/bin/env bash
# ============================================================================
# pre-commit hook — Z-ai-platform (parent orchestrator)
# ============================================================================
#
# Purpose:
#   Block commits that would break the standards tree or the cross-repo
#   ID graph. Runs in 3 phases:
#
#     Phase 0: Worklog freshness check (RULE-MONOLITH-002, WARN only)
#       - Verifies that docs/session/worklog.md was modified in the last
#         60 minutes (proxy for "did the agent document its work?")
#       - WARN only — false positives are common. Logged, not blocking.
#
#     Phase 1: verify-standards.js  — content-level invariants (V01-V11)
#       - Lives in the standards submodule. Fast (<1s).
#       - Checks: no emoji/Unicode graphic chars in code spans, fence
#         language tags, English-only, anti-monolith threshold values,
#         design-system delegation, README template structure, 1000-line
#         hard cap on standards/ + docs/sandbox/ + templates/ .md files.
#       - BLOCK: any invariant failure aborts the commit.
#
#     Phase 2: verify-id-graph.js   — structural / ID-graph invariants (G01-G15)
#       - Cross-repo: needs all 4 repos visible (parent + 3 submodules).
#       - Lives in standards submodule. Slower (~2-3s, scans 4 repos).
#       - Checks: no duplicate IDs, Related-edge resolution, layer matrix,
#         cycle detection, deprecated-ID window, typo-IDs, ZAI DAG,
#         Aligned_with symmetry.
#       - BLOCK: any HARD check failure aborts the commit.
#       - Soft warnings (W11-W15) do NOT block — they are advisory.
#
#   commit-msg hook (separate file) handles Conventional Commits format
#   validation on the commit MESSAGE (G4/G5/G6 of commit-work contract).
#
# Install (one-time, after cloning):
#   bash install-hooks.sh
#   (or equivalently: git config core.hooksPath .githooks && chmod +x .githooks/*)
#
# Bypass (NOT recommended — use only for emergencies like WIP snapshots):
#   git commit --no-verify
#
# Contract reference: skills/skills/commit-work/CONTRACT.md
# Runtime: skills/skills/commit-work/scripts/run-contract.sh
#
# ============================================================================

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# --- Phase 0: Worklog freshness check (RULE-MONOLITH-002, WARN) -------------
echo "[pre-commit] Phase 0/2: worklog freshness (RULE-MONOLITH-002, WARN only)"
WORKLOG="docs/session/worklog.md"
if [ -f "$WORKLOG" ]; then
  if [ "$(find "$WORKLOG" -mmin -60 2>/dev/null | wc -l)" -gt 0 ]; then
    echo "[pre-commit] OK: worklog updated within last 60 min"
  else
    echo "[pre-commit] WARN: worklog NOT updated within last 60 min"
    echo "[pre-commit]   Worklog: $WORKLOG"
    echo "[pre-commit]   Per RULE-MONOLITH-002, every action should be logged."
    echo "[pre-commit]   This is advisory — commit will proceed."
  fi
else
  echo "[pre-commit] WARN: worklog not found at $WORKLOG"
  echo "[pre-commit]   This is advisory — commit will proceed."
fi

# Locate Node.js. If absent, warn but allow commit (developer may be on
# minimal env; CI will catch any regressions).
if ! command -v node >/dev/null 2>&1; then
  echo "[pre-commit] WARNING: Node.js not found in PATH — skipping verifier runs."
  echo "[pre-commit] CI will catch any regressions; install Node.js to enable local checks."
  exit 0
fi

# Locate verifier scripts. They live in the standards submodule, which
# MUST be checked out (`git submodule update --init --recursive`).
VERIFY_STANDARDS="standards/scripts/verify-standards.js"
VERIFY_ID_GRAPH="standards/scripts/verify-id-graph.js"

if [ ! -f "$VERIFY_STANDARDS" ] || [ ! -f "$VERIFY_ID_GRAPH" ]; then
  echo "[pre-commit] WARNING: standards submodule not checked out — skipping verifier runs."
  echo "[pre-commit] Run: git submodule update --init --recursive"
  echo "[pre-commit] CI will catch any regressions."
  exit 0
fi

# --- Phase 1: verify-standards.js (fast, content-level) --------------------
echo "[pre-commit] Phase 1/2: verify-standards.js (content-level invariants V01-V11)"
if ! node "$VERIFY_STANDARDS" >/tmp/zai-precommit-vstandards.log 2>&1; then
  echo "[pre-commit] FAIL: verify-standards.js reported invariant violations."
  echo "[pre-commit] ---- output ----"
  cat /tmp/zai-precommit-vstandards.log | sed 's/^/  /'
  echo "[pre-commit] ---- end output ----"
  echo "[pre-commit] Either fix the offending standard(s), or if the invariant"
  echo "[pre-commit] itself changed, update the V## check in $VERIFY_STANDARDS."
  echo "[pre-commit] To bypass (NOT recommended): git commit --no-verify"
  exit 1
fi
echo "[pre-commit] OK: verify-standards.js PASS"
rm -f /tmp/zai-precommit-vstandards.log

# --- Phase 2: verify-id-graph.js (slower, cross-repo structural) -----------
echo "[pre-commit] Phase 2/2: verify-id-graph.js (cross-repo ID-graph invariants G01-G15)"
if ! node "$VERIFY_ID_GRAPH" >/tmp/zai-precommit-vgraph.log 2>&1; then
  echo "[pre-commit] FAIL: verify-id-graph.js reported HARD check violations."
  echo "[pre-commit] ---- output ----"
  cat /tmp/zai-precommit-vgraph.log | sed 's/^/  /'
  echo "[pre-commit] ---- end output ----"
  echo "[pre-commit] HARD check failures block CI. Fix the offending file(s)"
  echo "[pre-commit] (in the appropriate submodule if needed), then re-commit."
  echo "[pre-commit] To bypass (NOT recommended): git commit --no-verify"
  exit 1
fi
echo "[pre-commit] OK: verify-id-graph.js PASS (HARD checks)"
rm -f /tmp/zai-precommit-vgraph.log

# --- Phase 3: verify-skills.js (skills-side format, SOFT default) ------------
# Added 2026-06-21 per §9.2.2 of CI-AND-TESTING.md. Runs verify-skills.js
# in soft-default mode (S01/S04/S09 are HARD; S02/S03/S05 are SOFT until
# the existing 15 violations are remediated, then --strict can be flipped).
# Phase 3 is WARN-only at this stage — it reports violations but does NOT
# block commits. Once §9.2.2 remediation is complete, promote to BLOCK.
VERIFY_SKILLS="standards/scripts/verify-skills.js"
if [ -f "$VERIFY_SKILLS" ]; then
  echo "[pre-commit] Phase 3: verify-skills.js (skills-side format, SOFT default)"
  if ! node "$VERIFY_SKILLS" >/tmp/zai-precommit-vskills.log 2>&1; then
    echo "[pre-commit] WARN: verify-skills.js reported HARD violations (S01/S04/S09)."
    echo "[pre-commit] ---- output ----"
    cat /tmp/zai-precommit-vskills.log | sed 's/^/  /'
    echo "[pre-commit] ---- end output ----"
    echo "[pre-commit] SOFT warnings (S02/S03/S05) are pre-existing tech debt;"
    echo "[pre-commit] see standards/docs/CI-AND-TESTING.md §9.2.2 for remediation plan."
    echo "[pre-commit] NOT blocking commit — fix in a follow-up if this is your change."
  else
    # Even on PASS, check if there were SOFT warnings to surface
    if grep -q "WARN" /tmp/zai-precommit-vskills.log 2>/dev/null; then
      echo "[pre-commit] OK: verify-skills.js HARD PASS (SOFT warnings present, see log)"
    else
      echo "[pre-commit] OK: verify-skills.js PASS"
    fi
  fi
  rm -f /tmp/zai-precommit-vskills.log
else
  echo "[pre-commit] Phase 3: verify-skills.js NOT FOUND — skipping (Phase D1 in progress)"
fi

echo "[pre-commit] All checks PASS — proceeding with commit."
echo "[pre-commit] (commit-msg hook will validate Conventional Commits format next)"
exit 0
