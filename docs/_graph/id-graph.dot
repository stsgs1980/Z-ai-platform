    "ZAI-MEM-004" [label="ZAI-MEM-004\nSkill: Memory Export", fillcolor="#dcfce7", color="#166534", fontcolor="#14532d"];
    "ZAI-MEM-002" [label="ZAI-MEM-002\nSkill: Memory Query", fillcolor="#dcfce7", color="#166534", fontcolor="#14532d"];
    "ZAI-MEM-001" [label="ZAI-MEM-001\nSkill: Memory Store", fillcolor="#dcfce7", color="#166534", fontcolor="#14532d"];
    "ZAI-ARCH-001" [label="ZAI-ARCH-001\nSkill: Mermaid Diagramming", fillcolor="#dcfce7", color="#166534", fontcolor="#14532d"];
    "ZAI-STS-003" [label="ZAI-STS-003\nSkill: Performance Code Generator", fillcolor="#dcfce7", color="#166534", fontcolor="#14532d"];
    "ZAI-STS-005" [label="ZAI-STS-005\nSkill: Phi Layout", fillcolor="#dcfce7", color="#166534", fontcolor="#14532d"];
    "ZAI-DEV-001" [label="ZAI-DEV-001\nSkill: Project Clone", fillcolor="#dcfce7", color="#166534", fontcolor="#14532d"];
    "ZAI-STS-001" [label="ZAI-STS-001\nSkill: Prompt Engineering", fillcolor="#dcfce7", color="#166534", fontcolor="#14532d"];
