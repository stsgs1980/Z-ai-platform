    "ZAI-REQ-001" [label="ZAI-REQ-001\nSkill: Requirements Clarity", fillcolor="#dcfce7", color="#166534", fontcolor="#14532d"];
    "ZAI-SESSION-003" [label="ZAI-SESSION-003\nSession Experience", fillcolor="#dcfce7", color="#166534", fontcolor="#14532d"];
    "ZAI-SESSION-001" [label="ZAI-SESSION-001\nSession Log", fillcolor="#dcfce7", color="#166534", fontcolor="#14532d"];
    "ZAI-META-001" [label="ZAI-META-001\nSkill: Skill ID System", fillcolor="#dcfce7", color="#166534", fontcolor="#14532d"];
