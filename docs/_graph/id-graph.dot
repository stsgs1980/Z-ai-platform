digraph zai_id_graph {
  graph [
    rankdir=LR,
    splines=true,
    overlap=false,
    fontname="Helvetica",
    label="Z-ai Platform ID Graph\n60 nodes / 111 edges\nGenerated 2026-06-18",
    labelloc=t,
    fontsize=14,
    bgcolor="#fafafa"
  ];
  node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, penwidth=1.2];
  edge [fontname="Helvetica", fontsize=8, color="#666666"];
  subgraph cluster_L1 {
    label="L1 — Standards (STD-*)";
    style="filled,rounded"; fillcolor="#eff6ff"; color="#bfdbfe"; fontsize=12;
    "STD-AGENT-001" [label="STD-AGENT-001\nSubagent Standard", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-AGENT-002" [label="STD-AGENT-002\nOrchestration Standard", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-ARCH-001" [label="STD-ARCH-001\nArchitecture & Repo Layout", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-ARCH-002" [label="STD-ARCH-002\nImplementation Order", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-DESIGN-001" [label="STD-DESIGN-001\nDesign System Standard", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-DOC-002" [label="STD-DOC-002\nMarkdown Formatting", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-DOC-003" [label="STD-DOC-003\nNo-Unicode Policy", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-ENV-001" [label="STD-ENV-001\nReproducibility", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-ENV-002" [label="STD-ENV-002\nZ.ai Integration", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-ERR-001" [label="STD-ERR-001\nError Handling Core", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-ERR-002" [label="STD-ERR-002\nError Recovery", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-FE-001" [label="STD-FE-001\nFrontend Development", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-GIT-001" [label="STD-GIT-001\nGitHub Core", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-GIT-002" [label="STD-GIT-002\nGitHub Sandbox Safety", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-META-001" [label="STD-META-001\nStandard ID System", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-SEC-001" [label="STD-SEC-001\nSecurity Core", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-SEC-002" [label="STD-SEC-002\nSecurity Extended", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-SKILL-001" [label="STD-SKILL-001\nSkill Format & Identification", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
    "STD-TEST-001" [label="STD-TEST-001\nTesting", fillcolor="#dbeafe", color="#1e40af", fontcolor="#1e3a8a"];
  }
  subgraph cluster_L2 {
    label="L2 — Guard (RULE-*/PROC-*/TOOL-*)";
    style="filled,rounded"; fillcolor="#fffbeb"; color="#fde68a"; fontsize=12;
    "RULE-MONOLITH-001" [label="RULE-MONOLITH-001\nAnswer before act (no unsolicited action)", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-002" [label="RULE-MONOLITH-002\nworklog -- BEFORE and AFTER every action", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-003" [label="RULE-MONOLITH-003\nRead before write", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-004" [label="RULE-MONOLITH-004\nOne logical block -- one commit", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-005" [label="RULE-MONOLITH-005\nNo loops", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-006" [label="RULE-MONOLITH-006\nHonest reporting", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-007" [label="RULE-MONOLITH-007\nWork structure", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-008" [label="RULE-MONOLITH-008\nSandbox verification (no fake setup)", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-009" [label="RULE-MONOLITH-009\nSession Start Protocol (drift prevention)", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-010" [label="RULE-MONOLITH-010\nDocumentation sync (no code without docs)", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-011" [label="RULE-MONOLITH-011\nIntegrity protection (no self-sabotage)", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-012" [label="RULE-MONOLITH-012\nAnti-monolith (no file over 250 lines)", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-013" [label="RULE-MONOLITH-013\nUse ahg bump for version updates", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-014" [label="RULE-MONOLITH-014\nPre-commit mandatory checklist", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-015" [label="RULE-MONOLITH-015\nNo Unicode graphics (UNICODE_POLICY compliance)", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-016" [label="RULE-MONOLITH-016\nAHG submodule is immutable architecture (no removal, no inli", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
    "RULE-MONOLITH-017" [label="RULE-MONOLITH-017\nUpstream write protection (no consumer agent may push to AHG", fillcolor="#fef3c7", color="#92400e", fontcolor="#78350f"];
  }
  subgraph cluster_L3 {
    label="L3 — Skills (ZAI-*)";
